# ═══════════════════════════════════════════════════════════
#  SRE Agent – Environment Variables
#  Copy this file to .env and fill in your values.
#  Minimum required: GEMINI_API_KEY (everything else has
#  safe defaults for local demo mode).
# ═══════════════════════════════════════════════════════════

# ── AI / Gemini ─────────────────────────────────────────────
# Required for real triage. Without it, mock triage is used.
GEMINI_API_KEY=your api key here
GEMINI_MODEL=gemini-2.5-flash-lite

# ── Ticketing Provider ───────────────────────────────────────
# Options: mock | linear | jira
# "mock" works out-of-the-box with no external dependencies.
TICKETING_PROVIDER=mock

# Linear (if TICKETING_PROVIDER=linear)
LINEAR_API_KEY=lin_api_...
LINEAR_TEAM_ID=your-team-uuid

# Jira (if TICKETING_PROVIDER=jira)
JIRA_URL=https://yourorg.atlassian.net
JIRA_EMAIL=you@yourorg.com
JIRA_API_TOKEN=your-jira-api-token
JIRA_PROJECT_KEY=SRE

# ── Email ────────────────────────────────────────────────────
# Set MOCK_EMAIL=false to send real emails via SMTP.
MOCK_EMAIL=true

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
# For Gmail: use an App Password (not your account password)
SMTP_PASS=your-app-password

FROM_EMAIL=sre-agent@yourcompany.com
# Comma-separated list of on-call engineer emails
TEAM_EMAILS=oncall@yourcompany.com,sre-lead@yourcompany.com

# ── Communicator (Slack / Discord) ───────────────────────────
# Leave blank to skip. Both are optional.
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your-webhook-id/your-webhook-token
